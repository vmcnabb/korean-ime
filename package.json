{
  "name": "korean-ime",
  "version": "2.3.0",
  "description": "Allow people to type Hangul in Chrome when the OS does not have a Korean IME installed.",
  "private": true,
  "source": "src/manifest.json",
  "ts-node": {
    "project": "./tsconfig.json"
  },
  "scripts": {
    "test": "jest",
    "build": "npm run clean && npm run sync-version && npm run check && npm run lint && cross-env NODE_ENV=production parcel build",
    "start": "npm run sync-version && cross-env NODE_ENV=development parcel watch src/manifest.json --host localhost --config @parcel/config-webextension",
    "build-dev": "npm run clean && npm run sync-version && cross-env NODE_ENV=development parcel build --no-optimize",
    "clean": "rimraf dist obj .parcel-cache coverage",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "sync-version": "node scripts/sync-manifest-version.mjs",
    "package": "npm run build && node scripts/package.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmcnabb/korean-ime.git"
  },
  "author": "Vincent McNabb",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vmcnabb/korean-ime/issues"
  },
  "homepage": "https://github.com/vmcnabb/korean-ime#readme",
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@parcel/config-webextension": "^2.16.4",
    "@parcel/transformer-sass": "^2.16.4",
    "@parcel/transformer-vue": "^2.16.4",
    "@types/chrome": "^0.1.40",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "archiver": "^8.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "parcel": "^2.16.4",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vue": "^3.5.33"
  },
  "dependencies": {
    "reflect-metadata": "^0.1.13"
  }
}
