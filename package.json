{
  "name": "korean-ime",
  "version": "2.3.0",
  "description": "Allow people to type Hanguel in Chrome when the OS does not have a Korean IME installed.",
  "private": true,
  "source": "src/manifest.json",
  "ts-node": {
    "project": "./tsconfig.json"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run check && cross-env NODE_ENV=production parcel build",
    "start": "cross-env NODE_ENV=development parcel watch src/manifest.json --host localhost --config @parcel/config-webextension",
    "build-dev": "cross-env NODE_ENV=development parcel build --no-optimize",
    "check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmcnabb/korean-ime.git"
  },
  "author": "Vincent McNabb",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vmcnabb/korean-ime/issues"
  },
  "homepage": "https://github.com/vmcnabb/korean-ime#readme",
  "devDependencies": {
    "@babel/types": "^7.21.5",
    "@parcel/config-webextension": "^2.8.3",
    "@parcel/transformer-sass": "^2.8.3",
    "@parcel/transformer-vue": "^2.8.3",
    "@types/chrome": "0.0.231",
    "@types/node": "^18.16.3",
    "cross-env": "^7.0.3",
    "parcel": "^2.8.3",
    "process": "^0.11.10",
    "sass": "^1.62.0",
    "typescript": "^5.0.4",
    "vue": "^3.2.47"
  },
  "dependencies": {
    "reflect-metadata": "^0.1.13"
  }
}
