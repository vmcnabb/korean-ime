{
  "name": "korean-ime-i18n-hover",
  "publisher": "vmcnabb",
  "displayName": "Korean IME i18n Hover",
  "description": "Shows English Chrome i18n messages when hovering over message keys in this repo.",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vmcnabb/korean-ime.git",
    "directory": "tools/vscode-i18n-hover"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:koreanImeI18nHover.showStatus",
    "onLanguage:vue",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:javascript"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:test": "rimraf dist-test && tsc -p tsconfig.test.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist dist-test",
    "test": "npm run build:test && node --test dist-test/test/*.test.js",
    "vscode:prepublish": "npm run build"
  },
  "contributes": {
    "commands": [
      {
        "command": "koreanImeI18nHover.showStatus",
        "title": "Korean IME i18n Hover: Show Status"
      }
    ]
  }
}
