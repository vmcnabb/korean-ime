# EditorConfig — https://editorconfig.org
# Baseline editor settings for contributors not using the repo's VS Code config.
# Kept consistent with .prettierrc (4-space indent, no tabs, 120 print width).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# Markdown: trailing whitespace can be a meaningful line break, so don't trim.
[*.md]
trim_trailing_whitespace = false
